# === lamp_ai .env (develop, Option A: full auto) ===
SERVICE_NAME=lamp_ai

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092   # 로컬(Uvicorn)에서 실행 시
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092      # 같은 compose 안 컨테이너에서 실행 시
KAFKA_SOURCE_TOPIC=test-started
KAFKA_RESULT_TOPIC=ai-diagnosis-completed
KAFKA_GROUP_ID=lamp-ai-develop

# Model
PREDICT_THRESHOLD=0.5
# MODEL_PATH=...
# CONFIG_PATH=...
# S3_BUCKET=...
